{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PolyAnalyzer",
  "version": "2.0.0",
  "identifier": "com.polyanalyzer.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PolyAnalyzer",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/polyanalyzer-engine"
    ],
    "windows": {
      "allowDowngrades": true,
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false,
        "languages": ["SimpChinese", "English"],
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null
      }
    }
  },
  "plugins": {}
}
